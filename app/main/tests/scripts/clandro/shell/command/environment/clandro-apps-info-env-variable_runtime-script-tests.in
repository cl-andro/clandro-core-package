        local clandro_core__bash__taiev_options="$8"
        local clandro_core__bash__taiev_source_output_mode="$9"
        local clandro_core__bash__taiev_args="${10}"

        if [[ "$clandro_core__bash__taiev_source_output_mode" == "_" ]]; then
            clandro_core__bash__taiev_source_output_mode="output_variable"
        fi

        clandro_core__bash__taiev_source_output_mode_arg=" '$clandro_core__bash__taiev_source_output_mode'"

        if [[ "$clandro_core__bash__taiev_source_output_mode" != "-" ]] && \
                [[ "$clandro_core__bash__taiev_source_output_mode" != ">" ]]; then
            clandro_core__bash__taiev_source_print_command="${NL}printf '%s' \"\${$clandro_core__bash__taiev_source_output_mode:-}\""
        fi
