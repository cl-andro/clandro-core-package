source_file_from_path "clandro-apps-info-env-variable.bash" || exit $?'

    clandro_apps_info_env_file_path="$CLANDRO_CORE__TESTS__TMPDIR_PATH/clandro-apps-info.env"
    if [[ "$clandro_apps_info_env_file_export" == "true" ]]; then
        clandro_apps_info_env_file_create_command="printf '%s\n' '${clandro_apps_info_env_file_content//\'/\'\\\'\'}' > '${clandro_apps_info_env_file_path//\'/\'\\\'\'}' || exit \$?"
        get_export_scoped_variable_command clandro_apps_info_env_file_export_command "$CLANDRO_ENV__S_ROOT" "CORE__" "APPS_INFO_ENV_FILE" "$clandro_apps_info_env_file_path" || return $?
    else
