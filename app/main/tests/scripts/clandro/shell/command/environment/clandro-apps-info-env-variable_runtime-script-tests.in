        "" \
        "true" "$env_file" \
        0 "^${clandro_app__data_dir_escaped}$" \
        get-value "" _ "${clandro_core__taiev__scope_args} ${clandro_core__taiev__validator_and_values_args}" || return $?

    get_export_scoped_variable_command env_file "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" ".$clandro_app__data_dir" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_file-invalid-path" \
        "" \
        "true" "$env_file" \
        81 "^Failed to find a valid value .*$" \
        get-value "" _ "${clandro_core__taiev__scope_args} ${clandro_core__taiev__validator_and_values_args}" || return $?

    return 0

}
