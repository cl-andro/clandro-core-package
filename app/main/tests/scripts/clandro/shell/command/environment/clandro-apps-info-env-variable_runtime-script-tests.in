#!@CLANDRO__PREFIX@/bin/bash
# shellcheck shell=bash

##
# `clandro_core__clandro_apps_info_env_variable__run_tests`
##
clandro_core__clandro_apps_info_env_variable__run_tests() {

    clandro_core__tests__log 3 "clandro_core__clandro_apps_info_env_variable__run_tests()"

    clandro_core__sh__clandro_apps_info_env_variable__run_tests || return $?
    clandro_core__bash__clandro_apps_info_env_variable__run_tests || return $?

    return 0
}





clandro_core__sh__clandro_apps_info_env_variable__run_tests() {

    clandro_core__tests__log 3 "clandro_core__sh__clandro_apps_info_env_variable()"

    CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME="clandro_core__sh__clandro_apps_info_env_variable__run_test"
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST

    clandro_core__set_clandro_core_test_scoped_env_variables__default || return $?
    clandro_core__sh__clandro_apps_info_env_variable__run_tests_for_scope || return $?

    clandro_core__set_clandro_core_test_scoped_env_variables__foo || return $?
    clandro_core__sh__clandro_apps_info_env_variable__run_tests_for_scope || return $?

    return 0

}

clandro_core__sh__clandro_apps_info_env_variable__run_tests_for_scope() {

    local test_type
    local clandro_core__taiev__scope_args

    CLANDRO_ENV__S_ROOT="$CLANDRO_CORE__TESTS__CLANDRO_ENV__S_ROOT"


    clandro_core__clandro_apps_info_env_variable__test__usage "usage" \
        "APP__" "STRING" || return $?



    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}APP__"'"'
    test_types["scope-ss"]='ss="'APP__'"'
    test_types["component-name"]='cn="clandro-app"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__taiev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO_APP__STRING_DEFINED`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_string_defined "clandro-string-defined_${test_type}" \
            "APP__" "STRING_DEFINED" \
            "$clandro_core__taiev__scope_args"' "STRING_DEFINED"' '"*"' || return $?



        # `CLANDRO_APP__STRING_SET`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_string_set "clandro-string-set_${test_type}" \
            "APP__" "STRING_SET" \
            "$clandro_core__taiev__scope_args"' "STRING_SET"' '"?"' || return $?



        # `CLANDRO_APP__TARGET_SDK`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_app__target_sdk "clandro-app-target-sdk_${test_type}" \
            "APP__" "TARGET_SDK" \
            "$clandro_core__taiev__scope_args"' "TARGET_SDK"' || return $?


        # `CLANDRO_APP__DATA_DIR`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_app__data_dir "clandro-app-data-dir_${test_type}" \
            "APP__" "DATA_DIR" \
            "$clandro_core__taiev__scope_args"' "DATA_DIR"' 'p+="/*[!/]"' \
            "$CLANDRO_CORE__TESTS__CLANDRO_APP__DATA_DIR" || return $?
    done

    return 0

}

clandro_core__sh__clandro_apps_info_env_variable__run_test() {

    clandro_core__tests__validate_argument_count ge $# 7 clandro_core__sh__clandro_apps_info_env_variable__run_test "$@" || return $?

    local test_name="$1"
    local pre_test_commands="$2"
    local clandro_apps_info_env_file_export="$3"
    local clandro_apps_info_env_file_content="$4"
    local expected_exit_code="$5"
    local expected_output_regex="$6"
    local clandro_core__sh__taiev_command_type="$7"

    local clandro_apps_info_env_file_create_command
    local clandro_apps_info_env_file_export_command
    local clandro_apps_info_env_file_path
    local clandro_core__sh__taiev_call_command
    local clandro_core__sh__taiev_source_command
    local clandro_core__sh__taiev_source_output_mode_arg=""
    local clandro_core__sh__taiev_source_print_command=""

    if [[ "$clandro_core__sh__taiev_command_type" == "source-env" ]]; then
        clandro_core__tests__validate_argument_count eq $# 10 \
            "'clandro_core__sh__clandro_apps_info_env_variable__run_test' for the '$clandro_core__sh__taiev_command_type' command" "$@" || return $?

        local clandro_core__sh__taiev_options="$8"
        local clandro_core__sh__taiev_source_print_var="$9"
        local clandro_core__sh__taiev_args="${10}"

        if [[ "$clandro_core__sh__taiev_source_print_var" != "-" ]]; then
            clandro_core__sh__taiev_source_print_command="${NL}printf '%s' \"\${$clandro_core__sh__taiev_source_print_var:-}\""
        fi
    elif [[ "$clandro_core__sh__taiev_command_type" == "get-value" ]]; then
        clandro_core__tests__validate_argument_count eq $# 10 \
            "'clandro_core__sh__clandro_apps_info_env_variable__run_test' for the '$clandro_core__sh__taiev_command_type' command" "$@" || return $?

        local clandro_core__sh__taiev_options="$8"
        local clandro_core__sh__taiev_source_output_mode="$9"
        local clandro_core__sh__taiev_args="${10}"

        if [[ "$clandro_core__sh__taiev_source_output_mode" == "_" ]]; then
            clandro_core__sh__taiev_source_output_mode="output_variable"
        fi

        clandro_core__sh__taiev_source_output_mode_arg=" '$clandro_core__sh__taiev_source_output_mode'"

        if [[ "$clandro_core__sh__taiev_source_output_mode" != "-" ]] && \
                [[ "$clandro_core__sh__taiev_source_output_mode" != ">" ]]; then
            clandro_core__sh__taiev_source_print_command="${NL}printf '%s' \"\${$clandro_core__sh__taiev_source_output_mode:-}\""
        fi
    else
        local clandro_core__sh__taiev_args=""
    fi


    # shellcheck disable=SC2016
    clandro_core__sh__taiev_source_command='source_file_from_path() { local source_file="${1:-}"; [ $# -gt 0 ] && shift 1; local source_path; if source_path="$(command -v "$source_file")" && [ -n "$source_path" ]; then . "$source_path" || return $?; else echo "Failed to find the '\''$source_file'\'' file to source." 1>&2; return 1; fi; }'"${NL}${NL}"'
source_file_from_path "clandro-apps-info-env-variable.sh" --sourcing-script || exit $?'

    clandro_apps_info_env_file_path="$CLANDRO_CORE__TESTS__TMPDIR_PATH/clandro-apps-info.env"
    if [[ "$clandro_apps_info_env_file_export" == "true" ]]; then
        clandro_apps_info_env_file_create_command="printf '%s\n' '${clandro_apps_info_env_file_content//\'/\'\\\'\'}' > '${clandro_apps_info_env_file_path//\'/\'\\\'\'}' || exit \$?"
        get_export_scoped_variable_command clandro_apps_info_env_file_export_command "$CLANDRO_ENV__S_ROOT" "CORE__" "APPS_INFO_ENV_FILE" "$clandro_apps_info_env_file_path" || return $?
    else
        clandro_apps_info_env_file_create_command="printf '%s' '' > '${clandro_apps_info_env_file_path//\'/\'\\\'\'}' || exit \$?"
        get_unset_scoped_variable_command clandro_apps_info_env_file_export_command "$CLANDRO_ENV__S_ROOT" "CORE__" "APPS_INFO_ENV_FILE" || return $?
    fi

    pre_test_commands="export CLANDRO_ENV__S_ROOT='${CLANDRO_ENV__S_ROOT//\'/\'\\\'\'}';${NL}
unset CLANDRO_ENV__S_APP;${NL}${NL}\
${clandro_apps_info_env_file_create_command}${NL}${NL}${clandro_apps_info_env_file_export_command}${NL}${NL}\
${pre_test_commands:+"$pre_test_commands${NL}${NL}"}"

    clandro_core__sh__taiev_options="${clandro_core__sh__taiev_options:+"$clandro_core__sh__taiev_options "}"

    if [[ "$clandro_core__sh__taiev_command_type" == "get-value" ]]; then
        if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST:-}" != "true" ]]; then
            clandro_core__sh__taiev_call_command="clandro-apps-info-env-variable.sh"
            clandro_core__tests__run_script_test "clandro_core__sh__taiev__${test_name}__exec-stdout" \
                "#!/bin/sh${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__sh__taiev_call_command '$clandro_core__sh__taiev_command_type' ${clandro_core__sh__taiev_options}'>' $clandro_core__sh__taiev_args" \
                "$expected_exit_code" "$expected_output_regex" || return $?
        fi

        if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST:-}" != "true" ]]; then
            clandro_core__sh__taiev_call_command="${clandro_core__sh__taiev_source_command}${NL}${NL}clandro_core__sh__clandro_apps_info_env_variable"
            clandro_core__tests__run_script_test "clandro_core__sh__taiev__${test_name}__source-stdout" \
                "#!/bin/sh${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__sh__taiev_call_command '$clandro_core__sh__taiev_command_type' ${clandro_core__sh__taiev_options}'>' $clandro_core__sh__taiev_args" \
                "$expected_exit_code" "$expected_output_regex" || return $?
        fi
    fi

    if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST:-}" != "true" ]]; then
        clandro_core__sh__taiev_call_command="${clandro_core__sh__taiev_source_command}${NL}${NL}clandro_core__sh__clandro_apps_info_env_variable"
        clandro_core__tests__run_script_test "clandro_core__sh__taiev__${test_name}__source-var" \
            "#!/bin/sh${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__sh__taiev_call_command '$clandro_core__sh__taiev_command_type' ${clandro_core__sh__taiev_options}$clandro_core__sh__taiev_source_output_mode_arg $clandro_core__sh__taiev_args || exit \$?$clandro_core__sh__taiev_source_print_command" \
            "$expected_exit_code" "$expected_output_regex" || return $?
    fi

    return 0

}



clandro_core__bash__clandro_apps_info_env_variable__run_tests() {

    clandro_core__tests__log 3 "clandro_core__bash__clandro_apps_info_env_variable()"

    CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME="clandro_core__bash__clandro_apps_info_env_variable__run_test"
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST

    clandro_core__set_clandro_core_test_scoped_env_variables__default || return $?
    clandro_core__bash__clandro_apps_info_env_variable__run_tests_for_scope || return $?

    clandro_core__set_clandro_core_test_scoped_env_variables__foo || return $?
    clandro_core__bash__clandro_apps_info_env_variable__run_tests_for_scope || return $?

    return 0

}

clandro_core__bash__clandro_apps_info_env_variable__run_tests_for_scope() {

    local test_type
    local clandro_core__taiev__scope_args

    CLANDRO_ENV__S_ROOT="$CLANDRO_CORE__TESTS__CLANDRO_ENV__S_ROOT"


    clandro_core__clandro_apps_info_env_variable__test__usage "usage" \
        "APP__" "STRING" || return $?



    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}APP__"'"'
    test_types["scope-ss"]='ss="'APP__'"'
    test_types["component-name"]='cn="clandro-app"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__taiev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO_APP__STRING_DEFINED`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_string_defined "clandro-string-defined_${test_type}" \
            "APP__" "STRING_DEFINED" \
            "$clandro_core__taiev__scope_args"' "STRING_DEFINED"' '"*"' || return $?



        # `CLANDRO_APP__STRING_SET`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_string_set "clandro-string-set_${test_type}" \
            "APP__" "STRING_SET" \
            "$clandro_core__taiev__scope_args"' "STRING_SET"' '"?"' || return $?



        # `CLANDRO_APP__TARGET_SDK`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_app__target_sdk "clandro-app-target-sdk_${test_type}" \
            "APP__" "TARGET_SDK" \
            "$clandro_core__taiev__scope_args"' "TARGET_SDK"' || return $?


        # `CLANDRO_APP__DATA_DIR`.
        clandro_core__clandro_apps_info_env_variable__test__clandro_app__data_dir "clandro-app-data-dir_${test_type}" \
            "APP__" "DATA_DIR" \
            "$clandro_core__taiev__scope_args"' "DATA_DIR"' 'r+="^(/[^/]+)+$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO_APP__DATA_DIR" || return $?
    done

    return 0

}

clandro_core__bash__clandro_apps_info_env_variable__run_test() {

    clandro_core__tests__validate_argument_count ge $# 7 clandro_core__bash__clandro_apps_info_env_variable__run_test "$@" || return $?

    local test_name="$1"
    local pre_test_commands="$2"
    local clandro_apps_info_env_file_export="$3"
    local clandro_apps_info_env_file_content="$4"
    local expected_exit_code="$5"
    local expected_output_regex="$6"
    local clandro_core__bash__taiev_command_type="$7"

    local clandro_apps_info_env_file_create_command
    local clandro_apps_info_env_file_export_command
    local clandro_apps_info_env_file_path
    local clandro_core__bash__taiev_call_command
    local clandro_core__bash__taiev_source_command
    local clandro_core__bash__taiev_source_output_mode_arg=""
    local clandro_core__bash__taiev_source_print_command=""

    if [[ "$clandro_core__bash__taiev_command_type" == "source-env" ]]; then
