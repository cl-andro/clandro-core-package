    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_regex-match-positive_env-invalid_def-invalid" \
        "${env_command}" \
        81 "^Failed to find a valid value .*$" \
