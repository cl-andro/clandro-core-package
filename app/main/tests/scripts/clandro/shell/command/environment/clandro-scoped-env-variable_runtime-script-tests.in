clandro_core__bash__clandro_scoped_env_variable__run_test() {

    clandro_core__tests__validate_argument_count ge $# 5 clandro_core__bash__clandro_scoped_env_variable__run_test "$@" || return $?

    local test_name="$1"
    local pre_test_commands="$2"
    local expected_exit_code="$3"
    local expected_output_regex="$4"
    local clandro_core__bash__tsev_command_type="$5"

    local clandro_core__bash__tsev_call_command
    local clandro_core__bash__tsev_source_command
    local clandro_core__bash__tsev_source_output_mode_arg=""
    local clandro_core__bash__tsev_source_print_command=""

    if [[ "$clandro_core__bash__tsev_command_type" == "get-name" ]] || \
        [[ "$clandro_core__bash__tsev_command_type" == "get-value" ]]; then
        clandro_core__tests__validate_argument_count eq $# 7 \
            "'clandro_core__bash__clandro_scoped_env_variable__run_test' for the '$clandro_core__bash__tsev_command_type' command" "$@" || return $?

        local clandro_core__bash__tsev_source_output_mode="$6"
        local clandro_core__bash__tsev_args="$7"

        if [[ "$clandro_core__bash__tsev_source_output_mode" == "_" ]]; then
            clandro_core__bash__tsev_source_output_mode="output_variable"
        fi

        clandro_core__bash__tsev_source_output_mode_arg=" '$clandro_core__bash__tsev_source_output_mode'"

        if [[ "$clandro_core__bash__tsev_source_output_mode" != "-" ]] && \
                [[ "$clandro_core__bash__tsev_source_output_mode" != ">" ]]; then
            clandro_core__bash__tsev_source_print_command="${NL}printf '%s' \"\${$clandro_core__bash__tsev_source_output_mode:-}\""
        fi
    elif [[ "$clandro_core__bash__tsev_command_type" == "set-value" ]] || \
            [[ "$clandro_core__bash__tsev_command_type" == "unset-value" ]]; then
        clandro_core__tests__validate_argument_count eq $# 7 \
            "'clandro_core__bash__clandro_scoped_env_variable__run_test' for the '$clandro_core__bash__tsev_command_type' command" "$@" || return $?

        local clandro_core__bash__tsev_source_print_var="$6"
        local clandro_core__bash__tsev_args="$7"

        if [[ "$clandro_core__bash__tsev_source_print_var" != "-" ]]; then
            clandro_core__bash__tsev_source_print_command="${NL}printf '%s' \"\${$clandro_core__bash__tsev_source_print_var:-}\""
        fi
    else
        local clandro_core__bash__tsev_args=""
    fi


    pre_test_commands="export CLANDRO_ENV__S_ROOT='${CLANDRO_ENV__S_ROOT//\'/\'\\\'\'}'${NL}${NL}${pre_test_commands:+"$pre_test_commands${NL}${NL}"}"

    # shellcheck disable=SC2016
    clandro_core__bash__tsev_source_command='source_file_from_path() { local source_file="${1:-}"; [ $# -gt 0 ] && shift 1; local source_path; if source_path="$(command -v "$source_file")" && [ -n "$source_path" ]; then source "$source_path" || return $?; else echo "Failed to find the '\''$source_file'\'' file to source." 1>&2; return 1; fi; }'"${NL}${NL}"'
source_file_from_path "clandro-scoped-env-variable.bash" || exit $?'

    if [[ "$clandro_core__bash__tsev_command_type" == "get-name" ]] || \
        [[ "$clandro_core__bash__tsev_command_type" == "get-value" ]]; then
        if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST:-}" != "true" ]]; then
            clandro_core__bash__tsev_call_command="clandro-scoped-env-variable.bash"
            clandro_core__tests__run_script_test "clandro_core__bash__tsev__${test_name}__exec-stdout" \
                "#!/bin/bash${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__bash__tsev_call_command '$clandro_core__bash__tsev_command_type' '>' $clandro_core__bash__tsev_args" \
                "$expected_exit_code" "$expected_output_regex" || return $?
        fi

        if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST:-}" != "true" ]]; then
            clandro_core__bash__tsev_call_command="${clandro_core__bash__tsev_source_command}${NL}${NL}clandro_core__bash__clandro_scoped_env_variable"
            clandro_core__tests__run_script_test "clandro_core__bash__tsev__${test_name}__source-stdout" \
                "#!/bin/bash${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__bash__tsev_call_command '$clandro_core__bash__tsev_command_type' '>' $clandro_core__bash__tsev_args" \
                "$expected_exit_code" "$expected_output_regex" || return $?
        fi
    fi

    if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST:-}" != "true" ]]; then
        clandro_core__bash__tsev_call_command="${clandro_core__bash__tsev_source_command}${NL}${NL}clandro_core__bash__clandro_scoped_env_variable"
        clandro_core__tests__run_script_test "clandro_core__bash__tsev__${test_name}__source-var" \
            "#!/bin/bash${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__bash__tsev_call_command '$clandro_core__bash__tsev_command_type'$clandro_core__bash__tsev_source_output_mode_arg $clandro_core__bash__tsev_args || exit \$?$clandro_core__bash__tsev_source_print_command" \
            "$expected_exit_code" "$expected_output_regex" || return $?
    fi

    return 0

}





clandro_core__clandro_scoped_env_variable__test__usage() {

    clandro_core__tests__log 4 "${1}()"

    clandro_core__tests__validate_argument_count eq $# 3 clandro_core__clandro_scoped_env_variable__test__usage "$@" || return $?

    local test_label="$1"
    local var_sub_scope_name="$2"
    local var_sub_name="$3"

    local env_command

    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_command_unset" \
        "" \
        64 "^The command '' passed to \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' is not valid\..*$" \
        "" - "" || return $?

    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_command_invalid" \
        "" \
        64 "^The command 'get-value1' passed to \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' is not valid\..*$" \
        get-value1 - "" || return $?



    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-name_command_args_invalid-1" \
        "" \
        64 "^Invalid argument count 1 for the 'get-name' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects 3 arguments\..*$" \
        get-name - "" || return $?

    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-name_command_args_invalid-less" \
        "" \
        64 "^Invalid argument count 2 for the 'get-name' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects 3 arguments\..*$" \
        get-name - '2' || return $?


    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_command_args_invalid-1" \
        "" \
        64 "^Invalid argument count 1 for the 'get-value' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects minimum 4 arguments\..*$" \
        get-value - "" || return $?

    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_command_args_invalid-less" \
        "" \
        64 "^Invalid argument count 3 for the 'get-value' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects minimum 4 arguments\..*$" \
        get-value - '2 3' || return $?


    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_set-value_command_args_invalid-1" \
        "" \
        64 "^Invalid argument count 1 for the 'set-value' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects 3 arguments\..*$" \
        set-value - "1" || return $?

    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_set-value_command_args_invalid-less" \
        "" \
        64 "^Invalid argument count 2 for the 'set-value' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects 3 arguments\..*$" \
        set-value - '1 2' || return $?


    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_unset-value_command_args_invalid-less" \
        "" \
        64 "^Invalid argument count 1 for the 'unset-value' command\. The \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' function expects 2 arguments\..*$" \
        unset-value - "1" || return $?



    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_var-to-set_none" \
        "" \
        64 "^The output_mode '' argument passed to \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' is not a valid environment variable name, or equal to \`>\` or \`-\`\..*$" \
        get-value "" 'ss="_" "TEST" "*"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST

    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_var-to-set_invalid" \
        "" \
        64 "^The output_mode '1foo' argument passed to \
'clandro_core__([a-z_]+)__clandro_scoped_env_variable' is not a valid environment variable name, or equal to \`>\` or \`-\`\..*$" \
        get-value "1foo" 'ss="_" "TEST" "*"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST


    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-name_var-to-set_output-mode-stdout_value-valid" \
        "" \
        0 "^${CLANDRO_ENV__S_ROOT}_TEST$" \
        get-name ">" 'ss="_" "TEST"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST

