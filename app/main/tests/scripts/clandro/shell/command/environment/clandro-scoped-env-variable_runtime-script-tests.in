    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "_" "TEST" "foo" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_var-to-set_output-mode-stdout_value-valid" \
        "$env_command" \
        0 "^foo$" \
        get-value ">" 'ss="_" "TEST" "*"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST


    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-name_var-to-set_output-mode-dash_value-valid" \
        "" \
        0 "^$" \
        get-name "-" 'ss="_" "TEST"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST

    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "_" "TEST" "foo" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_var-to-set_output-mode-dash_value-valid" \
        "$env_command" \
        0 "^$" \
        get-value "-" 'ss="_" "TEST" "*"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST


    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "_" "TEST" "bar" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-name_var-to-set_var-already-set_value-set" \
        "$env_command" \
        0 "^${CLANDRO_ENV__S_ROOT}_TEST$" \
        get-name "${CLANDRO_ENV__S_ROOT}_TEST" 'ss="_" "TEST"' || return $?
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST

    CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true" CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST="true"
    get_unset_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "_" "TEST" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-name_var-to-set_var-already-set_value-unset" \
        "$env_command" \
