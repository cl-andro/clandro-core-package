#!@CLANDRO__PREFIX@/bin/bash
# shellcheck shell=bash

##
# `clandro_core__clandro_scoped_env_variable__run_tests`
##
clandro_core__clandro_scoped_env_variable__run_tests() {

    clandro_core__tests__log 3 "clandro_core__clandro_scoped_env_variable__run_tests()"

    clandro_core__sh__clandro_scoped_env_variable__run_tests || return $?
    clandro_core__bash__clandro_scoped_env_variable__run_tests || return $?

    return 0
}





clandro_core__sh__clandro_scoped_env_variable__run_tests() {

    clandro_core__tests__log 3 "clandro_core__sh__clandro_scoped_env_variable()"

    CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME="clandro_core__sh__clandro_scoped_env_variable__run_test"
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST

    clandro_core__set_clandro_core_test_scoped_env_variables__default || return $?
    clandro_core__sh__clandro_scoped_env_variable__run_tests_for_scope || return $?

    clandro_core__set_clandro_core_test_scoped_env_variables__foo || return $?
    clandro_core__sh__clandro_scoped_env_variable__run_tests_for_scope || return $?

    return 0

}

clandro_core__sh__clandro_scoped_env_variable__run_tests_for_scope() {

    local test_type
    local clandro_core__tsev__scope_args

    CLANDRO_ENV__S_ROOT="$CLANDRO_CORE__TESTS__CLANDRO_ENV__S_ROOT"


    clandro_core__clandro_scoped_env_variable__test__usage "usage" \
        "_" "STRING" || return $?

    clandro_core__sh__clandro_scoped_env_variable__test__usage "extended-usage" \
        "_" "STRING" || return $?


    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}_"'"'
    test_types["scope-ss"]='ss="'_'"'
    test_types["component-name"]='cn="clandro"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__tsev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO__STRING_DEFINED`.
        clandro_core__clandro_scoped_env_variable__test__clandro_string_defined "clandro-string-defined_${test_type}" \
            "_" "STRING_DEFINED" \
            "$clandro_core__tsev__scope_args"' "STRING_DEFINED"' '"*"' || return $?



        # `CLANDRO__STRING_SET`.
        clandro_core__clandro_scoped_env_variable__test__clandro_string_set "clandro-string-set_${test_type}" \
            "_" "STRING_SET" \
            "$clandro_core__tsev__scope_args"' "STRING_SET"' '"?"' || return $?



        # `CLANDRO__PACKAGE_NAME`.
        clandro_core__clandro_scoped_env_variable__test__clandro__package_name "clandro-package-name_${test_type}_regex" \
            "_" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'p-="*[!a-zA-Z0-9_.]*"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "false" "" || return $?

        CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true"
        # shellcheck disable=SC2016
        clandro_core__clandro_scoped_env_variable__test__clandro__package_name "clandro-package-name_${test_type}_command" \
            "_" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'c+="is_valid_android_app_package_name"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "true" 'is_valid_android_app_package_name() { printf "%s\n" "${1:-}" | grep -qE '\''^(()|([a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*)+))$'\'' && [ "${#1}" -le 255 ]; }' || return $?
        unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST



        # `CLANDRO__ROOTFS`.
        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-rootfs_${test_type}" \
            "_" "ROOTFS" \
            "$clandro_core__tsev__scope_args"' "ROOTFS"' 'p+="/|/*[!/]"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__ROOTFS" || return $?

        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-rootfs-as-android-rootfs_${test_type}" \
            "_" "ROOTFS" \
            "$clandro_core__tsev__scope_args"' "ROOTFS"' 'p+="/|/*[!/]"' \
            "/" || return $?


        # `CLANDRO__HOME`.
        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-home_${test_type}" \
            "_" "HOME" \
            "$clandro_core__tsev__scope_args"' "HOME"' 'p+="/*[!/]"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__HOME" || return $?


        # `CLANDRO__PREFIX`.
        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-prefix_${test_type}" \
            "_" "PREFIX" \
            "$clandro_core__tsev__scope_args"' "PREFIX"' 'p+="/*[!/]"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PREFIX" || return $?



        # `CLANDRO__USER_ID`.
        clandro_core__clandro_scoped_env_variable__test__clandro__user_id "clandro-user-id_${test_type}" \
            "_" "USER_ID" \
            "$clandro_core__tsev__scope_args"' "USER_ID"' 'p-="'\'\''|*[!0-9]*|0[0-9]*|????*"' || return $?
    done

    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}APP__"'"'
    test_types["scope-ss"]='ss="'APP__'"'
    test_types["component-name"]='cn="clandro-app"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__tsev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO_APP__PACKAGE_NAME`.
        clandro_core__clandro_scoped_env_variable__test__clandro_app__package_name "clandro-app-package-name_${test_type}_regex" \
            "APP__" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'p-="'\'\''|*[!a-zA-Z0-9_.]*"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "false" "" || return $?

        CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true"
        # shellcheck disable=SC2016.
        clandro_core__clandro_scoped_env_variable__test__clandro_app__package_name "clandro-app-package-name_${test_type}_command" \
            "APP__" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'c+="is_valid_android_app_package_name"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "true" 'is_valid_android_app_package_name() { printf "%s\n" "${1:-}" | grep -qE '\''^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*)+$'\'' && [ "${#1}" -le 255 ]; }' || return $?
        unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST

        done



    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}EXEC__"'"'
    test_types["scope-ss"]='ss="'EXEC__'"'
    test_types["component-name"]='cn="clandro-exec"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__tsev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO_EXEC__PROC_SELF_EXE`.
        # We cannot use `PROC_SELF_EXE` itself as `libclandro-exec` may modify/unset.
        clandro_core__clandro_scoped_env_variable__test__clandro_exec__proc_self_exe "clandro-exec-proc-self-exe_${test_type}" \
            "EXEC__" "PROC_SELF_EXE_TEST" \
            "$clandro_core__tsev__scope_args"' "PROC_SELF_EXE_TEST"' 'p+="'\'\''|/*[!/]"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PREFIX/bin/foo" || return $?

    done

    return 0

}



clandro_core__sh__clandro_scoped_env_variable__test__usage() {

    clandro_core__tests__log 4 "${1}()"

    clandro_core__tests__validate_argument_count eq $# 3 clandro_core__sh__clandro_scoped_env_variable__test__usage "$@" || return $?

    local test_label="$1"
    local var_sub_scope_name="$2"
    local var_sub_name="$3"

    local env_command

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "foo" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-positive_env-valid" \
        "${env_command}" \
        0 "^foo$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p+='foo|bar'" || return $?

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "baz" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-positive_env-invalid" \
        "${env_command}" \
        81 "^Failed to find a valid value .*$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p+='foo|bar'" || return $?

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "baz" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-positive_env-invalid_def-valid" \
        "${env_command}" \
        0 "^bar$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p+='foo|bar' bar" || return $?

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "baz" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-positive_env-invalid_def-invalid" \
        "${env_command}" \
        81 "^Failed to find a valid value .*$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p+='foo|bar' qux" || return $?



    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "baz" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-negative_env-valid" \
        "${env_command}" \
        0 "^baz$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p-='foo|bar'" || return $?

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "foo" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-negative_env-invalid" \
        "${env_command}" \
        81 "^Failed to find a valid value .*$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p-='foo|bar'" || return $?

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "foo" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-negative_env-invalid_def-valid" \
        "${env_command}" \
        0 "^baz$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p-='foo|bar' baz" || return $?

    get_export_scoped_variable_command env_command "$CLANDRO_ENV__S_ROOT" "$var_sub_scope_name" "$var_sub_name" "foo" || return $?
    "$CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME" "${test_label}_get-value_pattern-match-negative_env-invalid_def-invalid" \
        "${env_command}" \
        81 "^Failed to find a valid value .*$" \
        get-value _ "ss='$var_sub_scope_name' '$var_sub_name' p-='foo|bar' bar" || return $?

    return 0

}



clandro_core__sh__clandro_scoped_env_variable__run_test() {

    clandro_core__tests__validate_argument_count ge $# 5 clandro_core__sh__clandro_scoped_env_variable__run_test "$@" || return $?

    local test_name="$1"
    local pre_test_commands="$2"
    local expected_exit_code="$3"
    local expected_output_regex="$4"
    local clandro_core__sh__tsev_command_type="$5"

    local clandro_core__sh__tsev_call_command
    local clandro_core__sh__tsev_source_command
    local clandro_core__sh__tsev_source_output_mode_arg=""
    local clandro_core__sh__tsev_source_print_command=""

    if [[ "$clandro_core__sh__tsev_command_type" == "get-name" ]] || \
        [[ "$clandro_core__sh__tsev_command_type" == "get-value" ]]; then
        clandro_core__tests__validate_argument_count eq $# 7 \
            "'clandro_core__sh__clandro_scoped_env_variable__run_test' for the '$clandro_core__sh__tsev_command_type' command" "$@" || return $?

        local clandro_core__sh__tsev_source_output_mode="$6"
        local clandro_core__sh__tsev_args="$7"

        if [[ "$clandro_core__sh__tsev_source_output_mode" == "_" ]]; then
            clandro_core__sh__tsev_source_output_mode="output_variable"
        fi

        clandro_core__sh__tsev_source_output_mode_arg=" '$clandro_core__sh__tsev_source_output_mode'"

        if [[ "$clandro_core__sh__tsev_source_output_mode" != "-" ]] && \
                [[ "$clandro_core__sh__tsev_source_output_mode" != ">" ]]; then
            clandro_core__sh__tsev_source_print_command="${NL}printf '%s' \"\${$clandro_core__sh__tsev_source_output_mode:-}\""
        fi
    elif [[ "$clandro_core__sh__tsev_command_type" == "set-value" ]] || \
            [[ "$clandro_core__sh__tsev_command_type" == "unset-value" ]]; then
        clandro_core__tests__validate_argument_count eq $# 7 \
            "'clandro_core__sh__clandro_scoped_env_variable__run_test' for the '$clandro_core__sh__tsev_command_type' command" "$@" || return $?

        local clandro_core__sh__tsev_source_print_var="$6"
        local clandro_core__sh__tsev_args="$7"

        if [[ "$clandro_core__sh__tsev_source_print_var" != "-" ]]; then
            clandro_core__sh__tsev_source_print_command="${NL}printf '%s' \"\${$clandro_core__sh__tsev_source_print_var:-}\""
        fi
    else
        local clandro_core__sh__tsev_args=""
    fi


    pre_test_commands="export CLANDRO_ENV__S_ROOT='${CLANDRO_ENV__S_ROOT//\'/\'\\\'\'}'${NL}${NL}${pre_test_commands:+"$pre_test_commands${NL}${NL}"}"

    # shellcheck disable=SC2016
    clandro_core__sh__tsev_source_command='source_file_from_path() { local source_file="${1:-}"; [ $# -gt 0 ] && shift 1; local source_path; if source_path="$(command -v "$source_file")" && [ -n "$source_path" ]; then . "$source_path" || return $?; else echo "Failed to find the '\''$source_file'\'' file to source." 1>&2; return 1; fi; }'"${NL}${NL}"'
source_file_from_path "clandro-scoped-env-variable.sh" --sourcing-script || exit $?'

    if [[ "$clandro_core__sh__tsev_command_type" == "get-name" ]] || \
        [[ "$clandro_core__sh__tsev_command_type" == "get-value" ]]; then
        if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST:-}" != "true" ]]; then
            clandro_core__sh__tsev_call_command="clandro-scoped-env-variable.sh"
            clandro_core__tests__run_script_test "clandro_core__sh__tsev__${test_name}__exec-stdout" \
                "#!/bin/sh${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__sh__tsev_call_command '$clandro_core__sh__tsev_command_type' '>' $clandro_core__sh__tsev_args" \
                "$expected_exit_code" "$expected_output_regex" || return $?
        fi

        if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST:-}" != "true" ]]; then
            clandro_core__sh__tsev_call_command="${clandro_core__sh__tsev_source_command}${NL}${NL}clandro_core__sh__clandro_scoped_env_variable"
            clandro_core__tests__run_script_test "clandro_core__sh__tsev__${test_name}__source-stdout" \
                "#!/bin/sh${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__sh__tsev_call_command '$clandro_core__sh__tsev_command_type' '>' $clandro_core__sh__tsev_args" \
                "$expected_exit_code" "$expected_output_regex" || return $?
        fi
    fi

    if [[ "${CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST:-}" != "true" ]]; then
        clandro_core__sh__tsev_call_command="${clandro_core__sh__tsev_source_command}${NL}${NL}clandro_core__sh__clandro_scoped_env_variable"
        clandro_core__tests__run_script_test "clandro_core__sh__tsev__${test_name}__source-var" \
            "#!/bin/sh${NL}${NL}set -e -u${NL}${NL}${pre_test_commands}$clandro_core__sh__tsev_call_command '$clandro_core__sh__tsev_command_type'$clandro_core__sh__tsev_source_output_mode_arg $clandro_core__sh__tsev_args || exit \$?$clandro_core__sh__tsev_source_print_command" \
            "$expected_exit_code" "$expected_output_regex" || return $?
    fi

    return 0

}





clandro_core__bash__clandro_scoped_env_variable__run_tests() {

    clandro_core__tests__log 3 "clandro_core__bash__clandro_scoped_env_variable()"

    CLANDRO_CORE__TESTS__TEST_FUNC__FUNC_NAME="clandro_core__bash__clandro_scoped_env_variable__run_test"
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_STDOUT_TEST
    unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_SOURCE_VAR_TEST

    clandro_core__set_clandro_core_test_scoped_env_variables__default || return $?
    clandro_core__bash__clandro_scoped_env_variable__run_tests_for_scope || return $?

    clandro_core__set_clandro_core_test_scoped_env_variables__foo || return $?
    clandro_core__bash__clandro_scoped_env_variable__run_tests_for_scope || return $?

    return 0

}

clandro_core__bash__clandro_scoped_env_variable__run_tests_for_scope() {

    local test_type
    local clandro_core__tsev__scope_args

    CLANDRO_ENV__S_ROOT="$CLANDRO_CORE__TESTS__CLANDRO_ENV__S_ROOT"


    # Basic usage and errors.
    clandro_core__clandro_scoped_env_variable__test__usage "usage" \
        "_" "STRING" || return $?

    clandro_core__bash__clandro_scoped_env_variable__test__usage "extended-usage" \
        "_" "STRING" || return $?



    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}_"'"'
    test_types["scope-ss"]='ss="'_'"'
    test_types["component-name"]='cn="clandro"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__tsev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO__STRING_DEFINED`.
        clandro_core__clandro_scoped_env_variable__test__clandro_string_defined "clandro-string-defined_${test_type}" \
            "_" "STRING_DEFINED" \
            "$clandro_core__tsev__scope_args"' "STRING_DEFINED"' '"*"' || return $?



        # `CLANDRO__STRING_SET`.
        clandro_core__clandro_scoped_env_variable__test__clandro_string_set "clandro-string-set_${test_type}" \
            "_" "STRING_SET" \
            "$clandro_core__tsev__scope_args"' "STRING_SET"' '"?"' || return $?



        # `CLANDRO__PACKAGE_NAME`.
        clandro_core__clandro_scoped_env_variable__test__clandro__package_name "clandro-package-name_${test_type}_regex" \
            "_" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'r+="^(()|([a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*)+))$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "false" "" || return $?

        CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true"
        # shellcheck disable=SC2016
        clandro_core__clandro_scoped_env_variable__test__clandro__package_name "clandro-package-name_${test_type}_command" \
            "_" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'c+="is_valid_android_app_package_name"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "true" 'is_valid_android_app_package_name() { printf "%s\n" "${1:-}" | grep -qE '\''^(()|([a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*)+))$'\'' && [ "${#1}" -le 255 ]; }' || return $?
        unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST



        # `CLANDRO__ROOTFS`.
        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-rootfs_${test_type}" \
            "_" "ROOTFS" \
            "$clandro_core__tsev__scope_args"' "ROOTFS"' 'r+="^((/)|((/[^/]+)+))$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__ROOTFS" || return $?

        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-rootfs-as-android-rootfs_${test_type}" \
            "_" "ROOTFS" \
            "$clandro_core__tsev__scope_args"' "ROOTFS"' 'r+="^((/)|((/[^/]+)+))$"' \
            "/" || return $?


        # `CLANDRO__HOME`.
        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-home_${test_type}" \
            "_" "HOME" \
            "$clandro_core__tsev__scope_args"' "HOME"' 'r+="^(/[^/]+)+$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__HOME" || return $?


        # `CLANDRO__PREFIX`.
        clandro_core__clandro_scoped_env_variable__test__clandro_path "clandro-prefix_${test_type}" \
            "_" "PREFIX" \
            "$clandro_core__tsev__scope_args"' "PREFIX"' 'r+="^(/[^/]+)+$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PREFIX" || return $?



        # `CLANDRO__USER_ID`.
        clandro_core__clandro_scoped_env_variable__test__clandro__user_id "clandro-user-id_${test_type}" \
            "_" "USER_ID" \
            "$clandro_core__tsev__scope_args"' "USER_ID"' 'r+="^(([0-9])|([1-9][0-9]{0,2}))$"' || return $?
    done



    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}APP__"'"'
    test_types["scope-ss"]='ss="'APP__'"'
    test_types["component-name"]='cn="clandro-app"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__tsev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO_APP__PACKAGE_NAME`.
        clandro_core__clandro_scoped_env_variable__test__clandro_app__package_name "clandro-app-package-name_${test_type}_regex" \
            "APP__" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'r+="^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*)+$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "false" "" || return $?

        CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST="true"
        # shellcheck disable=SC2016
        clandro_core__clandro_scoped_env_variable__test__clandro_app__package_name "clandro-app-package-name_${test_type}_command" \
            "APP__" "PACKAGE_NAME" \
            "$clandro_core__tsev__scope_args"' "PACKAGE_NAME"' 'c+="is_valid_android_app_package_name"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PACKAGE_NAME" \
            "true" 'is_valid_android_app_package_name() { printf "%s\n" "${1:-}" | grep -qE '\''^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*)+$'\'' && [ "${#1}" -le 255 ]; }' || return $?
        unset CLANDRO_CORE__TESTS__TEST_FUNC__SKIP_EXEC_TEST
    done



    local -A test_types=()
    test_types["scope-s"]='s="'"${CLANDRO_ENV__S_ROOT}EXEC__"'"'
    test_types["scope-ss"]='ss="'EXEC__'"'
    test_types["component-name"]='cn="clandro-exec"'
    for test_type in "${!test_types[@]}"; do
        clandro_core__tsev__scope_args="${test_types["$test_type"]}"

        # `CLANDRO_EXEC__PROC_SELF_EXE`.
        # We cannot use `PROC_SELF_EXE` itself as `libclandro-exec` may modify/unset.
        clandro_core__clandro_scoped_env_variable__test__clandro_exec__proc_self_exe "clandro-exec-proc-self-exe_${test_type}" \
            "EXEC__" "PROC_SELF_EXE_TEST" \
            "$clandro_core__tsev__scope_args"' "PROC_SELF_EXE_TEST"' 'r+="^(()|((/[^/]+)+))$"' \
            "$CLANDRO_CORE__TESTS__CLANDRO__PREFIX/bin/foo" || return $?
    done

    return 0

}



clandro_core__bash__clandro_scoped_env_variable__test__usage() {

