#!@CLANDRO__PREFIX@/bin/bash
# shellcheck shell=bash


##
# `clandro_core_main_app__runtime_script_tests__main`
##
clandro_core_main_app__runtime_script_tests__main() {

    CLANDRO_CORE__TESTS__LOG_TAG="@CLANDRO__LNAME@-core-main-app.rs-tests"

    clandro_core__tests__log 4 "main()"


    # Run tests.
    clandro_core_main_app__runtime_script_tests__run_tests || return $?

    return 0
}

##
# `clandro_core_main_app__runtime_script_tests__run_tests`
##
clandro_core_main_app__runtime_script_tests__run_tests() {

    clandro_core__tests__log 2 "runTests(start)"

    CLANDRO_CORE__TESTS__TESTS_COUNT="0"
    CLANDRO_CORE__TESTS__LOG_EMPTY_LINE_AFTER_SCRIPT_TEST="true"



    (
        # shellcheck source=app/main/tests/scripts/clandro/shell/command/environment/clandro-shell-command-environment_runtime-script-tests.in
        clandro_core__tests__source_file_from_path \
            "$CLANDRO_CORE__TESTS__TESTS_PATH/app/main/scripts/clandro/shell/command/environment/clandro-shell-command-environment_runtime-script-tests" || exit $?
        ClandroShellCommandEnvioronment_runTests || exit $?
    ) || return $?



    clandro_core__tests__log 2 "runTests(end): $CLANDRO_CORE__TESTS__TESTS_COUNT tests completed"

    return 0
}
